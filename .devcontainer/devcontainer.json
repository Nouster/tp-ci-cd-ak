{
  "name": "TP CI/CD Dev Environment",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/app",
  "forwardPorts": [5000, 5001, 3306],
  "portsAttributes": {
    "5000": { "label": "Backend API", "onAutoForward": "notify" },
    "5001": { "label": "Frontend",    "onAutoForward": "openBrowser" },
    "3306": { "label": "MySQL DB",    "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "ms-python.black-formatter",
        "ms-azuretools.vscode-docker",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-mysql"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  },
  "postCreateCommand": "pip install --no-cache-dir -r /app/requirements.txt",
  "remoteUser": "root"
}
